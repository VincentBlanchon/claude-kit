{
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/hooks/statusline.sh"
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(rm *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/git-diagnostic.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/branch-guard.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/rappels.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-no-verify.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-dangerous-actions.sh"
          }
        ]
      },
      {
        "matcher": "mcp__Claude_Preview__preview_(start|screenshot|snapshot|click|fill|eval|resize)",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-preview-panel.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/lint-format.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/warn-frontend-slop.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/precompact-directive.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/typecheck-on-stop.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/suggest-patterns.sh"
          }
        ]
      }
    ]
  }
}
